datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  guest
  customer
  staff
  admin
  super_admin
}

enum UserStatus {
  active
  inactive
  suspended
}

model User {
  id                String             @id @default(uuid()) @db.Uuid
  email             String             @unique
  passwordHash      String             @map("password_hash")
  phone             String?
  firstName         String             @map("first_name")
  lastName          String             @map("last_name")
  role              UserRole           @default(customer)
  status            UserStatus         @default(active)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  deletedAt         DateTime?          @map("deleted_at")
  refreshTokens     RefreshToken[]
  verificationCodes VerificationCode[]
  rentalOrders      RentalOrder[]
  inspections       RentalInspection[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jti       String    @unique
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  @@map("refresh_tokens")
}

enum VerificationCodeType {
  email_verification
  login_otp
  password_reset
}

model VerificationCode {
  id         String               @id @default(uuid()) @db.Uuid
  userId     String               @map("user_id") @db.Uuid
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  code       String
  type       VerificationCodeType
  expiresAt  DateTime             @map("expires_at")
  createdAt  DateTime             @default(now()) @map("created_at")
  verifiedAt DateTime?            @map("verified_at")

  @@map("verification_codes")
}

model Sport {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  products    Product[]

  @@map("sports")
}

model Brand {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  products    Product[]

  @@map("brands")
}

model Category {
  id        String     @id @default(uuid()) @db.Uuid
  parentId  String?    @map("parent_id") @db.Uuid
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  name      String
  slug      String     @unique
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")
  products  Product[]

  @@map("categories")
}

enum ProductType {
  retail
  rental
  hybrid
}

model Product {
  id              String          @id @default(uuid()) @db.Uuid
  sportId         String          @map("sport_id") @db.Uuid
  sport           Sport           @relation(fields: [sportId], references: [id])
  brandId         String          @map("brand_id") @db.Uuid
  brand           Brand           @relation(fields: [brandId], references: [id])
  categoryId      String          @map("category_id") @db.Uuid
  category        Category        @relation(fields: [categoryId], references: [id])
  name            String
  slug            String          @unique
  description     String?
  type            ProductType
  retailPrice     Decimal?        @map("retail_price") @db.Decimal(12, 2)
  baseRentalRate  Decimal?        @map("base_rental_rate") @db.Decimal(12, 2)
  securityDeposit Decimal?        @map("security_deposit") @db.Decimal(12, 2)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")
  images          ProductImage[]
  inventoryUnits  InventoryUnit[]
  rentalOrderItems RentalOrderItem[]

  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("product_images")
}

enum InventoryStatus {
  available
  reserved
  rented
  maintenance
  damaged
}

model InventoryUnit {
  id                  String          @id @default(uuid()) @db.Uuid
  productId           String          @map("product_id") @db.Uuid
  product             Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  serialNumber        String?         @map("serial_number")
  inventoryCode       String          @unique @map("inventory_code")
  barcode             String?
  qrCode              String?         @map("qr_code")
  status              InventoryStatus @default(available)
  branch              String          @default("Main") // purchase branch
  purchasePrice       Decimal?        @map("purchase_price") @db.Decimal(12, 2)
  purchaseDate        DateTime?       @map("purchase_date")
  condition           String          @default("excellent")
  conditionNotes      String?         @map("condition_notes")
  maintenanceDueDate  DateTime?       @map("maintenance_due_date")
  lastMaintenanceDate DateTime?       @map("last_maintenance_date")
  currentBranch       String          @default("Main") @map("current_branch")
  currentLocation     String?         @map("current_location")
  lockerNumber        String?         @map("locker_number")
  remarks             String?
  availability        Boolean         @default(true)
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  @@map("inventory_units")
  rentalOrderItems    RentalOrderItem[]
  rentalHistories     RentalHistory[]
}

enum RentalOrderStatus {
  pending_payment
  reserved
  active
  returned
  cancelled
  overdue
}

model RentalOrder {
  id                     String            @id @default(uuid()) @db.Uuid
  customerId             String            @map("customer_id") @db.Uuid
  customer               User              @relation(fields: [customerId], references: [id])
  totalAmount            Decimal           @map("total_amount") @db.Decimal(12, 2)
  depositAmount          Decimal           @map("deposit_amount") @db.Decimal(12, 2)
  status                 RentalOrderStatus @default(pending_payment)
  pickupSlot             DateTime          @map("pickup_slot")
  digitalAgreementUrl    String?           @map("digital_agreement_url")
  pickupVerificationCode String?           @map("pickup_verification_code")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  deletedAt              DateTime?         @map("deleted_at")
  items                  RentalOrderItem[]
  payments               RentalPayment[]

  @@map("rental_orders")
}

model RentalOrderItem {
  id              String             @id @default(uuid()) @db.Uuid
  rentalOrderId   String             @map("rental_order_id") @db.Uuid
  rentalOrder     RentalOrder        @relation(fields: [rentalOrderId], references: [id], onDelete: Cascade)
  productId       String             @map("product_id") @db.Uuid
  product         Product            @relation(fields: [productId], references: [id])
  inventoryUnitId String?            @map("inventory_unit_id") @db.Uuid
  inventoryUnit   InventoryUnit?     @relation(fields: [inventoryUnitId], references: [id])
  startDate       DateTime           @map("start_date")
  endDate         DateTime           @map("end_date")
  rentalRate      Decimal            @map("rental_rate") @db.Decimal(12, 2)
  securityDeposit Decimal            @map("security_deposit") @db.Decimal(12, 2)
  returnedAt      DateTime?          @map("returned_at")
  inspections     RentalInspection[]
  penalties       RentalPenalty[]

  @@map("rental_order_items")
}

model RentalPayment {
  id            String      @id @default(uuid()) @db.Uuid
  rentalOrderId String      @map("rental_order_id") @db.Uuid
  rentalOrder   RentalOrder @relation(fields: [rentalOrderId], references: [id], onDelete: Cascade)
  amount        Decimal     @db.Decimal(12, 2)
  paymentMethod String      @map("payment_method")
  transactionId String      @map("transaction_id")
  status        String
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("rental_payments")
}

enum RentalInspectionType {
  pickup
  return
}

model RentalInspection {
  id                String               @id @default(uuid()) @db.Uuid
  rentalOrderItemId String               @map("rental_order_item_id") @db.Uuid
  rentalOrderItem   RentalOrderItem      @relation(fields: [rentalOrderItemId], references: [id], onDelete: Cascade)
  inspectorId       String               @map("inspector_id") @db.Uuid
  inspector         User                 @relation(fields: [inspectorId], references: [id])
  type              RentalInspectionType
  conditionScore    String               @map("condition_score") // excellent, good, fair, poor
  notes             String?
  createdAt         DateTime             @default(now()) @map("created_at")

  @@map("rental_inspections")
}

model RentalPenalty {
  id                String          @id @default(uuid()) @db.Uuid
  rentalOrderItemId String          @map("rental_order_item_id") @db.Uuid
  rentalOrderItem   RentalOrderItem @relation(fields: [rentalOrderItemId], references: [id], onDelete: Cascade)
  amount            Decimal         @db.Decimal(12, 2)
  reason            String          // late, damage, lost
  status            String          // unpaid, paid
  createdAt         DateTime        @default(now()) @map("created_at")

  @@map("rental_penalties")
}

model RentalHistory {
  id              String        @id @default(uuid()) @db.Uuid
  inventoryUnitId String        @map("inventory_unit_id") @db.Uuid
  inventoryUnit   InventoryUnit @relation(fields: [inventoryUnitId], references: [id], onDelete: Cascade)
  eventType       String        @map("event_type") // purchased, reserved, rented, returned, maintenance, available
  eventDetails    String?       @map("event_details")
  createdAt       DateTime      @default(now()) @map("created_at")

  @@map("rental_histories")
}
